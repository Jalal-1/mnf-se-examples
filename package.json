{
  "name": "mnf-se-examples",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*/contract",
    "apps/*/cli"
  ],
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "0.14.0",
    "@midnight-ntwrk/compact-js": "2.4.3",
    "@midnight-ntwrk/ledger-v7": "7.0.3",
    "@midnight-ntwrk/midnight-js-contracts": "3.2.0",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "3.2.0",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "3.2.0",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "3.2.0",
    "@midnight-ntwrk/midnight-js-network-id": "3.2.0",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "3.2.0",
    "@midnight-ntwrk/midnight-js-types": "3.2.0",
    "@midnight-ntwrk/midnight-js-utils": "3.2.0",
    "@midnight-ntwrk/wallet-sdk-facade": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-hd": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-shielded": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "2.0.0",
    "@midnight-ntwrk/wallet-sdk-address-format": "3.0.1",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "2.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "rxjs": "^7.8.1",
    "ws": "^8.19.0"
  },
  "scripts": {
    "postinstall": "npx patch-package",
    "docker:up": "docker compose -f docker/standalone.yml up -d",
    "docker:down": "docker compose -f docker/standalone.yml down",
    "docker:logs": "docker compose -f docker/standalone.yml logs -f",
    "docker:reset": "docker compose -f docker/standalone.yml down -v && docker compose -f docker/standalone.yml up -d",
    "counter": "npm -w @mnf-se/counter-cli run standalone",
    "token": "npm -w @mnf-se/token-cli run standalone",
    "election": "npm -w @mnf-se/election-cli run standalone",
    "counter:preview": "npm -w @mnf-se/counter-cli run preview",
    "token:preview": "npm -w @mnf-se/token-cli run preview",
    "election:preview": "npm -w @mnf-se/election-cli run preview",
    "build:counter": "cd apps/counter/contract && npm run compact && npm run build",
    "build:token": "cd apps/token/contract && npm run compact && npm run build",
    "build:election": "cd apps/election/contract && npm run compact && npm run build",
    "build:all": "npm run build:counter && npm run build:token && npm run build:election",
    "typecheck": "npx tsc -p apps/counter/cli/tsconfig.json --noEmit && npx tsc -p apps/token/cli/tsconfig.json --noEmit && npx tsc -p apps/election/cli/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "patch-package": "^8.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "smoldot": "npm:@aspect-build/empty@0.0.0"
  }
}
