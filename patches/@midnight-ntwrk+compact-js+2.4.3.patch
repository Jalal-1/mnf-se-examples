+// PATCH: Rehash BoundedMerkleTree entries after encode/decode round-trip.
+// The decode() call produces BMTs with missing internal hashes, causing
+// partitionTranscripts to fail with "attempted to take root of non-rehashed bmt".
+// See: https://github.com/Jalal-1/mnf-se-examples — election contract with BMT state.
+const rehashLedgerStateValue = (sv) => {
+    switch (sv.type()) {
+        case 'boundedMerkleTree': {
+            const tree = sv.asBoundedMerkleTree();
+            return tree ? LedgerStateValue.newBoundedMerkleTree(tree.rehash()) : sv;
+        }
+        case 'array': {
+            const arr = sv.asArray();
+            if (!arr) return sv;
+            let result = LedgerStateValue.newArray();
+            for (const child of arr) {
+                result = result.arrayPush(rehashLedgerStateValue(child));
+            }
+            return result;
+        }
+        default:
+            return sv;
+    }
+};
